VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Feature flags
# Show the real-time chat sidebar on game and hero sheet pages
VITE_CHAT_ENABLED=true
# Allow users to type and send messages manually (requires VITE_CHAT_ENABLED=true)
# When false the sidebar is read-only; only system messages (dice rolls etc.) appear
VITE_CHAT_INPUT_ENABLED=true
